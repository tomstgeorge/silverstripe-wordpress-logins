{
    "name": "tomstgeorge/silverstripe-wordpress-logins",
    "description": "SilverStripe 5 module for simple, symmetric login and password sync with WordPress, plus optional auto-login redirects.",
    "type": "silverstripe-vendormodule",
    "keywords": [
        "silverstripe",
        "CMS",
        "wordpress",
        "authentication",
        "single sign-on",
        "autologin"
    ],
    "license": "BSD-3-Clause",
    "require": {
        "silverstripe/framework": "^5.0",
        "silverstripe/admin": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "squizlabs/php_codesniffer": "^3.7",
        "silverstripe/standards": "^1",
        "phpstan/extension-installer": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "TomStGeorge\\SilverStripeWordpressLogins\\": "src/",
            "TomStGeorge\\SilverStripeWordpressLogins\\Tests\\": "tests/php/"
        }
    },
    "extra": {
        "expose": [
            "client/dist"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
